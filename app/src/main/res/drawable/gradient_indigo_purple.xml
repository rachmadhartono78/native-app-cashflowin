<?xml version="1.0" encoding="utf-8"?>
<!--
    Gradient drawable: Indigo (#6366F1) → Purple (#A855F7)
    Dipakai untuk elemen highlight di Cashflowin Web Theme:
    - FAB background
    - Header/hero card  
    - Badge atau chip highlight
    - Progress bar accent
    Orientasi: kiri ke kanan (horizontal feel modern fintech)
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <gradient
        android:type="linear"
        android:angle="135"
        android:startColor="#6366F1"
        android:centerColor="#8B5CF6"
        android:endColor="#A855F7" />

</shape>
